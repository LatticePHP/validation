{
    "name": "lattice/validation",
    "description": "DTO validation with attribute-based rules for LatticePHP",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "php",
        "framework",
        "validation",
        "dto",
        "attributes",
        "lattice"
    ],
    "homepage": "https://github.com/LatticePHP/framework",
    "support": {
        "issues": "https://github.com/LatticePHP/framework/issues",
        "source": "https://github.com/LatticePHP/validation"
    },
    "require": {
        "php": "^8.4",
        "lattice/contracts": "^1.0",
        "illuminate/validation": "^12.0",
        "illuminate/translation": "^12.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "Lattice\\Validation\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Lattice\\Validation\\Tests\\": "tests/"
        }
    }
}
