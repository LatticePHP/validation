{
    "name": "lattice/validation",
    "description": "DTO validation with attribute-based rules for LatticePHP",
    "type": "library",
    "license": "MIT",
    "minimum-stability": "dev",
    "prefer-stable": true,
    "repositories": [
        {
            "type": "path",
            "url": "../contracts"
        }
    ],
    "require": {
        "php": "^8.4",
        "lattice/contracts": "dev-main",
        "illuminate/validation": "^12.0",
        "illuminate/translation": "^12.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": { "Lattice\\Validation\\": "src/" }
    },
    "autoload-dev": {
        "psr-4": { "Lattice\\Validation\\Tests\\": "tests/" }
    }
}
